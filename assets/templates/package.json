{
  "name": "@scope/package-name",
  "version": "0.1.0",
  "description": "Reusable library extracted from an existing application feature.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint:pkg": "publint && attw --pack .",
    "pack:dry": "npm pack --dry-run",
    "prepack": "npm run build && npm test && npm run typecheck"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {},
  "peerDependencies": {},
  "devDependencies": {
    "@arethetypeswrong/cli": "latest",
    "publint": "latest",
    "tsdown": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
